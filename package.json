{
  "name": "homzie",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "npm run infra:up && npm run dev",
    "dev:full": "npm run selfhost:start",
    "dev:stop": "node scripts/stop-local.mjs && docker compose -p homzie_dev down",
    "selfhost:bootstrap": "docker compose -p homzie_selfhost up -d postgres redis && npm run db:migrate && npm run db:seed:admin",
    "selfhost:start": "docker compose -p homzie_selfhost up --build -d",
    "selfhost:start:public": "docker compose -p homzie_selfhost --profile tunnel up --build -d",
    "selfhost:stop": "docker compose -p homzie_selfhost --profile tunnel down",
    "selfhost:deploy": "node --env-file=.env scripts/deploy-selfhost.mjs",
    "selfhost:logs": "docker compose -p homzie_selfhost --profile tunnel logs -f web caddy postgres redis cloudflared",
    "selfhost:status": "docker compose -p homzie_selfhost --profile tunnel ps",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "infra:up": "docker compose -p homzie_dev up -d postgres redis",
    "infra:down": "docker compose -p homzie_dev down",
    "infra:logs": "docker compose -p homzie_dev logs -f postgres redis",
    "infra:status": "docker compose -p homzie_dev ps",
    "db:generate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env scripts/migrate.mjs",
    "db:studio": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio",
    "db:view": "npm run db:studio",
    "db:seed:admin": "node --env-file=.env scripts/seed-admin.mjs",
    "db:seed:seller": "node --env-file=.env scripts/seed-seller.mjs",
    "db:seed:catalog": "node --env-file=.env scripts/seed-catalog.mjs",
    "db:setup": "npm run infra:up && npm run db:migrate && npm run db:seed:admin && npm run db:seed:seller && npm run db:seed:catalog",
    "local:start": "npm run db:setup && npm run dev",
    "local:stop": "npm run dev:stop"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.12.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
