{
  "name": "homzie",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "npm run local:start",
    "dev:full": "npm run selfhost:start",
    "dev:stop": "node scripts/stop-local.mjs && docker compose -p homzie_dev down",
    "selfhost:bootstrap": "docker compose --env-file /mnt/c/Homzie/config/homzie.env -p homzie_selfhost up -d postgres redis && node --env-file=/mnt/c/Homzie/config/homzie.env scripts/migrate.mjs && node --env-file=/mnt/c/Homzie/config/homzie.env scripts/seed-admin.mjs",
    "selfhost:start": "docker compose --env-file /mnt/c/Homzie/config/homzie.env -p homzie_selfhost --profile selfhost up --build -d",
    "selfhost:start:public": "docker compose --env-file /mnt/c/Homzie/config/homzie.env -p homzie_selfhost --profile selfhost --profile tunnel up --build -d",
    "selfhost:stop": "docker compose -p homzie_selfhost --profile selfhost --profile tunnel down",
    "selfhost:deploy": "node --env-file=/mnt/c/Homzie/config/homzie.env scripts/deploy-selfhost.mjs",
    "selfhost:logs": "docker compose -p homzie_selfhost --profile tunnel logs -f web worker realtime coturn caddy postgres redis cloudflared",
    "selfhost:status": "docker compose -p homzie_selfhost --profile tunnel ps",
    "build": "next build",
    "start": "next start",
    "start:messages": "node scripts/message-realtime-server.mjs",
    "worker:reels": "node --env-file=.env --import tsx scripts/reel-render-worker.ts",
    "lint": "eslint",
    "infra:up": "docker compose -p homzie_dev up -d postgres redis",
    "infra:down": "docker compose -p homzie_dev down",
    "infra:logs": "docker compose -p homzie_dev logs -f postgres redis",
    "infra:status": "docker compose -p homzie_dev ps",
    "db:generate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env scripts/migrate.mjs",
    "db:studio": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio",
    "db:view": "npm run db:studio",
    "db:seed:admin": "node --env-file=.env scripts/seed-admin.mjs",
    "push:vapid": "web-push generate-vapid-keys --json",
    "db:setup": "npm run infra:up && npm run db:migrate && npm run db:seed:admin",
    "local:start": "node scripts/start-local.mjs",
    "local:stop": "npm run dev:stop"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@socket.io/redis-adapter": "^8.3.0",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.7.0",
    "@types/web-push": "^3.6.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "emoji-picker-react": "^4.19.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
